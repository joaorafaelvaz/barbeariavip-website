[Unit]
Description=Barbearia VIP - FastAPI Blog API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/barbeariavip-website
Environment="PATH=/usr/local/bin:/usr/bin"
Environment="JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING"
ExecStart=/usr/local/bin/uvicorn api.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
